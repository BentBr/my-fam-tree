{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                fm.user_id,\n                fm.role::text  AS \"role!\",\n                fm.joined_at,\n                u.email::text  AS \"email!\",\n                u.display_name AS \"display_name!\"\n            FROM family_memberships fm\n            JOIN users u ON u.id = fm.user_id\n            WHERE fm.family_id = $1\n            ORDER BY\n                CASE fm.role\n                    WHEN 'owner' THEN 0\n                    WHEN 'admin' THEN 1\n                    ELSE 2\n                END,\n                u.display_name\n            ",
