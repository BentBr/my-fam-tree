  "query": "SELECT id, family_id, email::text AS \"email!\", invited_role::text AS \"role!\",\n                      invited_by, person_id, expires_at, accepted_at\n                 FROM family_invites\n                WHERE family_id = $1 AND accepted_at IS NULL AND expires_at > now()\n                ORDER BY created_at DESC",
