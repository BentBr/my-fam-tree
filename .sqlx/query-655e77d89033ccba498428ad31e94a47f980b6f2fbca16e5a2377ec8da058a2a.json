  "query": "SELECT id, family_id, email::text AS \"email!\", invited_role::text AS \"role!\",\n                      invited_by, person_id, expires_at, accepted_at\n                 FROM family_invites\n                WHERE family_id = $1\n                  AND lower(email::text) = lower($2)\n                  AND accepted_at IS NULL\n                  AND expires_at > now()\n                LIMIT 1",
