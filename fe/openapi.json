{
  "openapi": "3.1.0",
  "info": {
    "title": "my-family API",
    "description": "Family platform API",
    "license": {
      "name": "BUSL-1.1",
      "identifier": "BUSL-1.1"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin"
    }
  ],
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseBody"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiErrorBody": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "code"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          },
          "fields": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/FieldViolation"
            }
          },
          "instance": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "auth_unauthenticated",
          "auth_token_expired",
          "auth_token_invalid",
          "auth_refresh_invalid",
          "auth_magic_link_invalid",
          "family_not_member",
          "family_insufficient_role",
          "family_invite_expired",
          "person_not_found",
          "person_not_editable",
          "contact_not_found",
          "contact_not_editable",
          "reminder_not_found",
          "relationship_cycle",
          "partnership_duplicate",
          "validation_failed",
          "conflict_stale",
          "rate_limited",
          "upstream",
          "internal"
        ]
      },
      "FieldViolation": {
        "type": "object",
        "description": "A single field validation failure on the wire.\n\n- `path`: JSON Pointer or query/header path to the offending field (e.g.\n  `/email`, `/body/family_name`, `/headers/x-family-id`).\n- `code`: stable i18n key (e.g. `validation.email_invalid`,\n  `validation.string_too_long`). FE looks this up in en/de catalogs.\n- `message`: English fallback so non-FE clients still get a readable\n  error.\n- `params`: named placeholders FE substitutes into the localized\n  message. Always serialized (even when empty) so FE clients don't have\n  to guard `params?.max`. Use e.g. `{\"max\": 100, \"actual\": 105}`.",
        "required": [
          "path",
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "params": {
            "type": "object",
            "additionalProperties": {},
            "propertyNames": {
              "type": "string"
            }
          },
          "path": {
            "type": "string"
          }
        }
      },
      "Health": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "HealthResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Health"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "NullResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {},
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "Pagination": {
        "type": "object",
        "description": "Cursor-based pagination block. `next_cursor` is `None` on the last page.",
        "required": [
          "limit",
          "returned"
        ],
        "properties": {
          "limit": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "returned": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "ResponseMeta": {
        "type": "object",
        "description": "Per-response metadata. Currently carries pagination cursors and the\n`request_id` for tracing-friendly client diagnostics.",
        "properties": {
          "pagination": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Pagination"
              }
            ]
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "cookie_access": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access"
      }
    }
  },
  "tags": [
    {
      "name": "health",
      "description": "Liveness and readiness"
    }
  ]
}
