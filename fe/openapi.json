{
  "openapi": "3.1.0",
  "info": {
    "title": "my-family API",
    "description": "Family platform API",
    "license": {
      "name": "BUSL-1.1",
      "identifier": "BUSL-1.1"
    },
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin"
    }
  ],
  "paths": {
    "/api/v1/auth/consume": {
      "post": {
        "tags": [
          "auth"
        ],
        "operationId": "consume",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConsumeReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Magic link consumed, session established",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsumeResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "Magic link invalid or expired"
          }
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": [
          "auth"
        ],
        "operationId": "logout",
        "responses": {
          "200": {
            "description": "Logged out",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutResponseBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/magic-link": {
      "post": {
        "tags": [
          "auth"
        ],
        "operationId": "magic_link",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MagicLinkReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Magic link sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MagicLinkResponseBody"
                }
              }
            }
          },
          "422": {
            "description": "Invalid email"
          },
          "429": {
            "description": "Rate limited"
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "operationId": "me",
        "responses": {
          "200": {
            "description": "Current session claims",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session"
          }
        }
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "tags": [
          "auth"
        ],
        "operationId": "refresh",
        "responses": {
          "200": {
            "description": "Session refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsumeResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "Refresh token invalid or expired"
          }
        }
      }
    },
    "/api/v1/families": {
      "post": {
        "tags": [
          "families"
        ],
        "operationId": "create",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateFamilyReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Family created and caller auto-joined as Owner",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateFamilyResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session"
          },
          "422": {
            "description": "Validation failed"
          }
        }
      }
    },
    "/api/v1/families/me": {
      "get": {
        "tags": [
          "families"
        ],
        "operationId": "list_mine",
        "responses": {
          "200": {
            "description": "Caller's family memberships",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MyFamiliesResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session"
          }
        }
      }
    },
    "/api/v1/families/{id}": {
      "delete": {
        "tags": [
          "families"
        ],
        "operationId": "delete_family",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Family deleted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NullResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session"
          },
          "403": {
            "description": "Insufficient role"
          }
        }
      },
      "patch": {
        "tags": [
          "families"
        ],
        "operationId": "rename",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RenameFamilyReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Family renamed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FamilyViewResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session"
          },
          "403": {
            "description": "Insufficient role"
          },
          "422": {
            "description": "Validation failed"
          }
        }
      }
    },
    "/api/v1/families/{id}/invites": {
      "post": {
        "tags": [
          "families"
        ],
        "operationId": "invite",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InviteReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Invite created and email queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InviteResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session"
          },
          "403": {
            "description": "Insufficient role"
          },
          "422": {
            "description": "Validation failed"
          }
        }
      }
    },
    "/api/v1/health": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseBody"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/invites/accept": {
      "post": {
        "tags": [
          "invites"
        ],
        "operationId": "accept",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AcceptReq"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Invite accepted, membership inserted, session refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AcceptResponseBody"
                }
              }
            }
          },
          "401": {
            "description": "No session or invite token invalid"
          },
          "410": {
            "description": "Invite expired"
          },
          "422": {
            "description": "Invite belongs to a different email"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AcceptReq": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "AcceptRes": {
        "type": "object",
        "required": [
          "family",
          "claims"
        ],
        "properties": {
          "claims": {
            "$ref": "#/components/schemas/ConsumeRes"
          },
          "family": {
            "$ref": "#/components/schemas/FamilyView"
          }
        }
      },
      "AcceptResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/AcceptRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "ApiErrorBody": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status",
          "code"
        ],
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          },
          "fields": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/FieldViolation"
            }
          },
          "instance": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "ConsumeReq": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "ConsumeRes": {
        "type": "object",
        "required": [
          "user_id",
          "email",
          "locale",
          "families"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "families": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FamilyClaim"
            }
          },
          "locale": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ConsumeResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/ConsumeRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "CreateFamilyReq": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "CreateFamilyRes": {
        "type": "object",
        "required": [
          "family",
          "claims"
        ],
        "properties": {
          "claims": {
            "$ref": "#/components/schemas/ConsumeRes"
          },
          "family": {
            "$ref": "#/components/schemas/FamilyView"
          }
        }
      },
      "CreateFamilyResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CreateFamilyRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "ErrorCode": {
        "type": "string",
        "enum": [
          "auth_unauthenticated",
          "auth_token_expired",
          "auth_token_invalid",
          "auth_refresh_invalid",
          "auth_magic_link_invalid",
          "family_not_member",
          "family_insufficient_role",
          "family_invite_expired",
          "person_not_found",
          "person_not_editable",
          "contact_not_found",
          "contact_not_editable",
          "reminder_not_found",
          "relationship_cycle",
          "partnership_duplicate",
          "validation_failed",
          "conflict_stale",
          "rate_limited",
          "upstream",
          "internal"
        ]
      },
      "FamilyClaim": {
        "type": "object",
        "required": [
          "id",
          "name",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        }
      },
      "FamilyView": {
        "type": "object",
        "required": [
          "id",
          "name",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        }
      },
      "FamilyViewResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/FamilyView"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "FieldViolation": {
        "type": "object",
        "description": "A single field validation failure on the wire.\n\n- `path`: JSON Pointer or query/header path to the offending field (e.g.\n  `/email`, `/body/family_name`, `/headers/x-family-id`).\n- `code`: stable i18n key (e.g. `validation.email_invalid`,\n  `validation.string_too_long`). FE looks this up in en/de catalogs.\n- `message`: English fallback so non-FE clients still get a readable\n  error.\n- `params`: named placeholders FE substitutes into the localized\n  message. Always serialized (even when empty) so FE clients don't have\n  to guard `params?.max`. Use e.g. `{\"max\": 100, \"actual\": 105}`.",
        "required": [
          "path",
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "params": {
            "type": "object",
            "additionalProperties": {},
            "propertyNames": {
              "type": "string"
            }
          },
          "path": {
            "type": "string"
          }
        }
      },
      "Health": {
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        }
      },
      "HealthResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/Health"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "InviteReq": {
        "type": "object",
        "required": [
          "email",
          "role"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        }
      },
      "InviteRes": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "InviteResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/InviteRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "JwtClaims": {
        "type": "object",
        "required": [
          "iss",
          "aud",
          "sub",
          "email",
          "locale",
          "families",
          "iat",
          "exp",
          "jti"
        ],
        "properties": {
          "aud": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "exp": {
            "type": "integer",
            "format": "int64"
          },
          "families": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FamilyClaim"
            }
          },
          "iat": {
            "type": "integer",
            "format": "int64"
          },
          "iss": {
            "type": "string"
          },
          "jti": {
            "type": "string"
          },
          "locale": {
            "type": "string"
          },
          "sub": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "LogoutRes": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "LogoutResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/LogoutRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "MagicLinkReq": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "MagicLinkRes": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "MagicLinkResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/MagicLinkRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "MeResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/ConsumeRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "MyFamiliesRes": {
        "type": "object",
        "required": [
          "families"
        ],
        "properties": {
          "families": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FamilyView"
            }
          }
        }
      },
      "MyFamiliesResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {
            "$ref": "#/components/schemas/MyFamiliesRes"
          },
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "NullResponseBody": {
        "type": "object",
        "required": [
          "data"
        ],
        "properties": {
          "data": {},
          "meta": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ResponseMeta"
              }
            ]
          }
        }
      },
      "Pagination": {
        "type": "object",
        "description": "Cursor-based pagination block. `next_cursor` is `None` on the last page.",
        "required": [
          "limit",
          "returned"
        ],
        "properties": {
          "limit": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "next_cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "returned": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "RenameFamilyReq": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "ResponseMeta": {
        "type": "object",
        "description": "Per-response metadata. Currently carries pagination cursors and the\n`request_id` for tracing-friendly client diagnostics.",
        "properties": {
          "pagination": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Pagination"
              }
            ]
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Role": {
        "type": "string",
        "enum": [
          "user",
          "admin",
          "owner"
        ]
      }
    },
    "securitySchemes": {
      "cookie_access": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access"
      }
    }
  },
  "tags": [
    {
      "name": "health",
      "description": "Liveness and readiness"
    },
    {
      "name": "auth",
      "description": "Authentication"
    },
    {
      "name": "families",
      "description": "Family management"
    },
    {
      "name": "invites",
      "description": "Invite acceptance"
    }
  ]
}
