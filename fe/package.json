{
    "name": "my-family-fe",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite --port 5173",
        "build": "vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "format": "prettier --write .",
        "typecheck": "vue-tsc --noEmit",
        "openapi-codegen": "openapi-typescript ./openapi.json -o ./src/api/schema.d.ts",
        "test": "vue-tsc --noEmit && vitest run",
        "test:e2e": "playwright test -c e2e/playwright.config.ts",
        "knip": "knip",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@mdi/font": "^7.4.47",
        "@tanstack/vue-query": "^5.59.0",
        "@vueuse/core": "^11.0.0",
        "d3-hierarchy": "^3.1.2",
        "d3-selection": "^3.0.0",
        "d3-zoom": "^3.0.0",
        "lucide-vue-next": "^0.460.0",
        "openapi-fetch": "^0.13.0",
        "pinia": "^2.3.0",
        "vue": "^3.5.0",
        "vue-i18n": "^11.0.0",
        "vue-router": "^4.4.0",
        "vuetify": "^3.7.0"
    },
    "devDependencies": {
        "@playwright/experimental-ct-vue": "^1.49.0",
        "@playwright/test": "^1.49.0",
        "@types/d3-hierarchy": "^3.1.7",
        "@types/d3-selection": "^3.0.10",
        "@types/d3-zoom": "^3.0.8",
        "@types/node": "^22.0.0",
        "@vitejs/plugin-vue": "^5.1.0",
        "@vitest/coverage-v8": "^2.1.0",
        "@vue/eslint-config-prettier": "^10.0.0",
        "@vue/eslint-config-typescript": "^14.0.0",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^9.13.0",
        "eslint-plugin-vue": "^9.30.0",
        "globals": "^17.6.0",
        "happy-dom": "^15.7.0",
        "knip": "^5.30.0",
        "openapi-typescript": "^7.4.0",
        "prettier": "^3.3.0",
        "sass-embedded": "^1.80.0",
        "typescript": "^5.6.0",
        "vite": "^6.0.0",
        "vite-plugin-vuetify": "^2.0.4",
        "vitest": "^2.1.0",
        "vue-tsc": "^2.1.0"
    },
    "packageManager": "pnpm@9.12.0"
}
