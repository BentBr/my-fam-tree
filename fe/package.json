{
    "name": "my-fam-tree-fe",
    "private": true,
    "version": "0.1.5",
    "type": "module",
    "scripts": {
        "dev": "vite --port 5173",
        "generate:images": "node scripts/generate-images.js",
        "build": "pnpm run generate:images && vue-tsc --noEmit && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "format": "prettier --write .",
        "typecheck": "vue-tsc --noEmit",
        "openapi-codegen": "openapi-typescript ./openapi.json -o ./src/api/schema.d.ts",
        "test": "vue-tsc --noEmit && vitest run",
        "test:e2e": "playwright test -c e2e/playwright.config.ts",
        "knip": "knip",
        "coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@lucide/vue": "^1.17.0",
        "@tanstack/vue-query": "^5.100.14",
        "d3-ease": "^3.0.1",
        "d3-selection": "^3.0.0",
        "d3-transition": "^3.0.1",
        "d3-zoom": "^3.0.0",
        "openapi-fetch": "^0.17.0",
        "pinia": "^3.0.4",
        "vue": "^3.5.35",
        "vue-i18n": "^11.0.0",
        "vue-router": "^5.1.0",
        "vuetify": "^4.0.8"
    },
    "devDependencies": {
        "@playwright/experimental-ct-vue": "^1.49.0",
        "@playwright/test": "^1.49.0",
        "@types/d3-ease": "^3.0.2",
        "@types/d3-selection": "^3.0.10",
        "@types/d3-transition": "^3.0.9",
        "@types/d3-zoom": "^3.0.8",
        "@types/node": "^25.9.1",
        "@types/pg": "^8.20.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.7",
        "@vue/eslint-config-prettier": "^10.0.0",
        "@vue/eslint-config-typescript": "^14.0.0",
        "@vue/test-utils": "^2.4.10",
        "eslint": "^10.4.1",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "happy-dom": "^20.9.0",
        "knip": "^6.14.2",
        "openapi-typescript": "^7.4.0",
        "pg": "^8.21.0",
        "prettier": "^3.3.0",
        "sass-embedded": "^1.100.0",
        "sharp": "^0.34.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.14",
        "vite-plugin-vuetify": "^2.0.4",
        "vitest": "^4.1.7",
        "vue-tsc": "^3.3.2"
    },
    "packageManager": "pnpm@10.33.4",
    "pnpm": {
        "onlyBuiltDependencies": [
            "sharp"
        ]
    }
}
