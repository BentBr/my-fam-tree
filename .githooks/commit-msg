#!/usr/bin/env bash
set -e

if [ "${GIT_HOOK_SKIP:-0}" = "1" ]; then exit 0; fi

msg_file="$1"
first_line=$(head -n 1 "$msg_file")

# Allow merge commits, revert commits, and Dependabot-style messages.
case "$first_line" in
    Merge*|Revert*|"build(deps):"*) exit 0 ;;
esac

pattern='^(feat|fix|chore|refactor|test|docs|ci|build|perf|style)(\([a-z0-9_-]+\))?: .{1,72}$'
if ! [[ "$first_line" =~ $pattern ]]; then
    echo "ERROR: commit subject must match Conventional Commits."
    echo "  pattern: $pattern"
    echo "  yours  : $first_line"
    echo "  examples: 'feat(api): add /persons endpoint', 'fix(tree): handle empty parents'"
    exit 1
fi
