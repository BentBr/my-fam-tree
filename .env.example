# my-family environment configuration.
# Local dev: `cp .env.example .env`, then edit values below.
# Production: set these as real environment variables. .env is never read in prod.

# ─────────────────────────────────────────────────────────────────────────────
# Runtime / process
# ─────────────────────────────────────────────────────────────────────────────
# development | staging | production
APP_ENV=development
RUST_LOG=info,my_family=debug
# pretty | json
LOG_FORMAT=pretty

# ─────────────────────────────────────────────────────────────────────────────
# HTTP server
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
# Routing: dinghy (or any *.docker DNS daemon) maps these subdomains to the
# right compose service. There are NO host port bindings on api/fe/mailpit/redis/worker.
# If you DO NOT want to run dinghy, use the `compose.ci.yaml` override which
# re-adds port bindings + uses localhost URLs.
API_PUBLIC_URL=http://api.my-family.docker
WEB_PUBLIC_URL=http://my-family.docker
CORS_ALLOWED_ORIGINS=http://my-family.docker
# Swagger UI + /api/docs/openapi.json. Keep FALSE on production releases so the
# API surface isn't published; set true only for local/staging exploration.
API_ENABLE_DOCS=false
API_METRICS_BIND=0.0.0.0:9090

# ─────────────────────────────────────────────────────────────────────────────
# Database
# `.env` holds host-perspective URLs (this file is read by host-side cargo,
# sqlx-cli, the migrator binary in dev). Inside compose, services get
# DATABASE_URL from `x-rust-env` in compose.yaml (which uses port 5432 on the
# docker network). The two coexist; container env always wins for services.
#
# Port 3458 is the host-bound side of the postgres container's 5432
# (deliberately non-default to avoid clashing with a local Postgres install).
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://my_family:my_family@postgres.my-family.docker:3458/my_family
DATABASE_MAX_CONNECTIONS=20
DATABASE_ACQUIRE_TIMEOUT_SECONDS=5
DATABASE_STATEMENT_TIMEOUT_MS=30000
# SQLX_OFFLINE=true # uncomment in CI

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis.my-family.docker:6379

REDIS_MAX_CONNECTIONS=10
REDIS_KEY_PREFIX=my-family:

# ─────────────────────────────────────────────────────────────────────────────
# JWT / auth (Ed25519).
# IMPORTANT: these three vars are intentionally OMITTED below — `.env.example`
# must NOT define them. After `cp .env.example .env`, generate keys with:
#   cargo run -p my-family-api --bin gen-jwt-keys >> .env
# That binary appends three lines (JWT_PRIVATE_KEY_ID, JWT_PRIVATE_KEY,
# JWT_PUBLIC_KEYS) to your local .env. dotenvy honors the first occurrence of
# each var; if you accidentally add placeholders here, gen-jwt-keys' appended
# values are ignored and the API fails to verify tokens.
# docker compose's `${JWT_PRIVATE_KEY:?required}` syntax also correctly fails
# `rdt start` until you've run gen-jwt-keys.
# ─────────────────────────────────────────────────────────────────────────────
# JWT_PRIVATE_KEY_ID= # appended by gen-jwt-keys
# JWT_PRIVATE_KEY= # appended by gen-jwt-keys
# JWT_PUBLIC_KEYS= # appended by gen-jwt-keys
JWT_ISSUER=my-family
JWT_AUDIENCE=my-family-app
# 15min
JWT_ACCESS_TTL_SECONDS=900
# 30d
JWT_REFRESH_TTL_SECONDS=2592000
# 90d
JWT_REFRESH_ABSOLUTE_TTL_SECONDS=7776000

# ─────────────────────────────────────────────────────────────────────────────
# Cookies
# ─────────────────────────────────────────────────────────────────────────────
# parent domain so FE + API share cookies; "" in prod
COOKIE_DOMAIN=.my-family.docker
# true in prod
COOKIE_SECURE=false
COOKIE_SAMESITE_ACCESS=Lax
COOKIE_SAMESITE_REFRESH=Strict

# ─────────────────────────────────────────────────────────────────────────────
# Magic links & invites
# ─────────────────────────────────────────────────────────────────────────────
MAGIC_LINK_TTL_SECONDS=900
INVITE_TTL_SECONDS=1209600
MAGIC_LINK_RATE_PER_EMAIL_PER_HOUR=5
MAGIC_LINK_RATE_PER_IP_PER_HOUR=20

# ─────────────────────────────────────────────────────────────────────────────
# Email (SMTP DSN; schemes: smtp, smtp+starttls, smtps)
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_DSN=smtp://localhost:1025
EMAIL_FROM_NAME=my-family
EMAIL_FROM_ADDRESS=no-reply@my-family.local
EMAIL_REPLY_TO=
EMAIL_TIMEOUT_SECONDS=10

# ─────────────────────────────────────────────────────────────────────────────
# Worker (reminder digests + janitor sweeps)
# ─────────────────────────────────────────────────────────────────────────────
WORKER_TICK_INTERVAL_SECONDS=300
WORKER_LEADER_LEASE_SECONDS=60
WORKER_LEADER_REFRESH_SECONDS=20
WORKER_MAX_RETRIES=5
WORKER_RETRY_BACKOFF_MIN_SECONDS=60
WORKER_RETRY_BACKOFF_MAX_SECONDS=43200
WORKER_METRICS_BIND=0.0.0.0:9091
# Janitor — periodically DELETEs expired magic_link_tokens / refresh_tokens /
# family_invites / family_owner_transfers rows. Runs under the leader lock.
WORKER_JANITOR_INTERVAL_SECONDS=300
WORKER_JANITOR_GRACE_SECONDS=86400
# Outbox dispatcher — drains the durable email_outbox table over SMTP. The
# pollers use FOR UPDATE SKIP LOCKED so the pool size scales out safely.
WORKER_OUTBOX_POLL_SECONDS=1
WORKER_OUTBOX_POOL_SIZE=4

# ─────────────────────────────────────────────────────────────────────────────
# Object storage — person photos (Phase 5 Task 5)
# ─────────────────────────────────────────────────────────────────────────────
# `s3` talks to any S3-compatible endpoint (MinIO in dev, AWS S3 / R2 in prod);
# `local` writes under target/uploads for tests that don't want MinIO.
STORAGE_DRIVER=s3
STORAGE_BUCKET=my-family
STORAGE_REGION=us-east-1
# For real AWS S3 leave STORAGE_ENDPOINT_URL empty and FORCE_PATH_STYLE=false.
# In dev the api/worker reach MinIO through the `minio-api` nginx proxy on
# port 80 so presigned URLs don't pin to MinIO's internal :9000.
STORAGE_ENDPOINT_URL=http://minio-api.my-family.docker
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true

# ─────────────────────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
